{
  "name": "vibemote",
  "version": "0.1.0",
  "description": "Remote Claude Code control via Discord",
  "type": "module",
  "bin": {
    "vibemote": "./dist/index.js"
  },
  "files": [
    "src",
    "dist",
    "package.json",
    "README.md",
    "LICENSE",
    "tsconfig.json"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/daemon.ts src/tray.ts --format esm --clean --external systray2",
    "dev": "tsup src/index.ts src/daemon.ts src/tray.ts --format esm --watch --external systray2",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test": "vitest run",
    "prepare": "npm run build",
    "postinstall": "node -e \"const{chmodSync,existsSync}=require('fs');const{join}=require('path');const p=join(__dirname,'node_modules/systray2/traybin/tray_darwin_release');if(existsSync(p))chmodSync(p,0o755);const l=join(__dirname,'node_modules/systray2/traybin/tray_linux_release');if(existsSync(l))chmodSync(l,0o755)\""
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/james/vibemote.git"
  },
  "bugs": {
    "url": "https://github.com/james/vibemote/issues"
  },
  "homepage": "https://github.com/james/vibemote#readme",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.71",
    "commander": "^14.0.3",
    "discord.js": "^14.18.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "systray2": "^2.1.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.57.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}

{
  "name": "claude-control",
  "version": "0.1.0",
  "description": "Remote Claude Code control via Telegram",
  "type": "module",
  "bin": {
    "claude-control": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/daemon.ts --format esm --clean",
    "dev": "tsup src/index.ts src/daemon.ts --format esm --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.71",
    "@grammyjs/auto-retry": "^2.0.2",
    "commander": "^14.0.3",
    "grammy": "^1.41.1",
    "node-wav": "^0.0.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "smart-whisper": "^0.8.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}

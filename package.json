{
  "name": "disclaw",
  "version": "0.2.2",
  "description": "Remote Claude Code control via Discord",
  "type": "module",
  "bin": {
    "disclaw": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/daemon.ts src/tray.ts --format esm --clean --external systray2",
    "dev": "tsup src/index.ts src/daemon.ts src/tray.ts --format esm --watch --external systray2",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test": "vitest run",
    "prepare": "npm run build",
    "postinstall": "node --input-type=module -e \"import{chmodSync,existsSync}from'node:fs';import{join,dirname}from'node:path';import{fileURLToPath}from'node:url';const d=dirname(fileURLToPath(import.meta.url));for(const b of['tray_darwin_release','tray_linux_release']){const p=join(d,'node_modules/systray2/traybin',b);if(existsSync(p))chmodSync(p,0o755);}\""
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kloogans/disclaw.git"
  },
  "homepage": "https://github.com/kloogans/disclaw",
  "bugs": {
    "url": "https://github.com/kloogans/disclaw/issues"
  },
  "keywords": [
    "claude",
    "discord",
    "claude-code",
    "agent-sdk",
    "daemon",
    "remote",
    "cli"
  ],
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.71",
    "commander": "^14.0.3",
    "discord.js": "^14.18.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "systray2": "^2.1.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.57.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
